default_platform(:ios)

platform :ios do
  desc "Build und Upload zu TestFlight (App Store Connect API, automatische Cloud-Signierung)"
  lane :beta do
    # p8-Schluessel in Datei schreiben (xcodebuild braucht einen Pfad)
    key_path = File.expand_path("AuthKey.p8")
    File.write(key_path, ENV["ASC_KEY_P8"])

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: key_path,
      in_house: false
    )

    # Build-Nummer = GitHub-Run-Nummer (TestFlight verlangt steigende Nummern)
    increment_build_number(
      xcodeproj: "ios/App/App.xcodeproj",
      build_number: ENV["BUILD_NUMBER"]
    )

    # Archiv bauen + automatische Cloud-Signierung. Die -authenticationKey*-
    # Parameter geben xcodebuild den API-Key, damit -allowProvisioningUpdates
    # Distribution-Cert + Provisioning-Profil selbst erstellen kann.
    build_app(
      project: "ios/App/App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates " \
              "-authenticationKeyPath #{key_path} " \
              "-authenticationKeyID #{ENV['ASC_KEY_ID']} " \
              "-authenticationKeyIssuerID #{ENV['ASC_ISSUER_ID']} " \
              "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']}",
      export_options: {
        signingStyle: "automatic",
        teamID: ENV["APPLE_TEAM_ID"]
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
