default_platform(:ios)

platform :ios do
  desc "Build und Upload zu TestFlight (match Distribution-Signierung)"
  lane :beta do
    # CI-Keychain anlegen + entsperren (verhindert codesign-Hang: ohne das
    # wartet codesign auf einen Keychain-Zugriffs-Dialog, der auf CI nie kommt).
    setup_ci

    # App Store Connect API-Key (p8 in Datei schreiben)
    key_path = File.expand_path("AuthKey.p8")
    File.write(key_path, ENV["ASC_KEY_P8"])
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: key_path,
      in_house: false
    )

    # Distribution-Zertifikat + App-Store-Profil holen/erstellen.
    # Persistiert verschluesselt im privaten Cert-Repo (ueberlebt CI-Runs).
    match(
      type: "appstore",
      api_key: api_key,
      app_identifier: "app.bergkoenig.www",
      git_url: "git@github.com:Soellerhaus/bergkoenig-fastlane-certs.git",
      readonly: false
    )

    increment_build_number(
      xcodeproj: "ios/App/App.xcodeproj",
      build_number: ENV["BUILD_NUMBER"]
    )

    # Projekt auf manuelle Signierung mit dem match-Profil setzen
    update_code_signing_settings(
      path: "ios/App/App.xcodeproj",
      use_automatic_signing: false,
      team_id: ENV["APPLE_TEAM_ID"],
      bundle_identifier: "app.bergkoenig.www",
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore app.bergkoenig.www"
    )

    build_app(
      project: "ios/App/App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        teamID: ENV["APPLE_TEAM_ID"],
        provisioningProfiles: {
          "app.bergkoenig.www" => "match AppStore app.bergkoenig.www"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
