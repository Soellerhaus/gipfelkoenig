{
  "appId": "app.bergkoenig.www",
  "appName": "Bergkönig",
  "webDir": "frontend",
  "server": {
    "androidScheme": "https",
    "url": "https://bergkoenig.app",
    "allowNavigation": ["bergkoenig.app", "www.bergkoenig.app"]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#1a1814"
    },
    "Geolocation": {
      "enableHighAccuracy": true
    }
  }
}
